# Variables de entorno del frontend (Vite).
# Copiar este archivo como ".env" y completar con los valores de tu proyecto
# de Supabase (Project Settings > API).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------
# Nota: "admin-users" (api/admin-users.js) es una Vercel Function, no una
# Edge Function de Supabase (reemplazó a la Edge Function original — ver
# docs/SECURITY.md). Usa SUPABASE_SERVICE_ROLE_KEY como variable de entorno
# normal de Vercel (Project Settings > Environment Variables), no como
# secreto de Supabase.
# -----------------------------------------------------------------------
